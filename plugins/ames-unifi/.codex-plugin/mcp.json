{
  "mcpServers": {
    "ames-unifi-mcp": {
      "command": "bash",
      "args": [
        "-c",
        "cd /tmp && npx -y ames-unifi-mcp@latest"
      ],
      "env_vars": [
        "UNIFI_HOST",
        "UNIFI_API_KEY",
        "UNIFI_USERNAME",
        "UNIFI_PASSWORD",
        "UNIFI_SITE",
        "UNIFI_VERIFY_SSL",
        "UNIFI_TOOL_MODE",
        "UNIFI_PERMISSION_PROFILE",
        "OP_SERVICE_ACCOUNT_TOKEN"
      ]
    }
  }
}
