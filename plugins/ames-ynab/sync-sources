#!/usr/bin/env python3
"""Refresh source snapshots from upstream GitHub repositories."""

from __future__ import annotations

import json
import shutil
import subprocess
import tempfile
from pathlib import Path

HERE = Path(__file__).resolve().parent
MANIFEST = HERE / "update-sources.json"
DEST_ROOT = HERE / "sources"
EXCLUDES = {
    ".DS_Store",
    ".git",
    ".a5c",
    ".claude",
    ".firecrawl",
    "node_modules",
    "__pycache__",
    ".venv",
    "venv",
}


def should_skip(path: Path) -> bool:
    if any(part in EXCLUDES for part in path.parts):
        return True
    if path.name.startswith(".env") and path.name != ".env.example":
        return True
    return False


def copy_tree(src: Path, dest: Path) -> None:
    if dest.exists():
        shutil.rmtree(dest)
    dest.mkdir(parents=True)
    for path in src.rglob("*"):
        rel = path.relative_to(src)
        if should_skip(rel):
            continue
        target = dest / rel
        if path.is_dir():
            target.mkdir(parents=True, exist_ok=True)
        elif path.is_file():
            target.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(path, target)


def git(*args: str, cwd: Path | None = None) -> str:
    return subprocess.check_output(["git", *args], cwd=cwd, text=True).strip()


def main() -> None:
    specs = json.loads(MANIFEST.read_text())
    DEST_ROOT.mkdir(parents=True, exist_ok=True)
    wanted = set()

    with tempfile.TemporaryDirectory(prefix="ames-connector-sources-") as tmp:
        tmp_root = Path(tmp)
        for name, spec in specs.items():
            repo = spec["repo"]
            branch = spec.get("branch", "main")
            checkout = tmp_root / name
            git("clone", "--depth", "1", "--branch", branch, repo, str(checkout))
            commit = git("rev-parse", "HEAD", cwd=checkout)
            dest = DEST_ROOT / name
            copy_tree(checkout, dest)
            (dest / "_source.json").write_text(json.dumps({
                "name": name,
                "package": spec.get("package"),
                "repo": repo,
                "branch": branch,
                "commit": commit,
            }, indent=2) + "
")
            wanted.add(name)
            print(f"synced source: {name}@{commit[:12]}")

    for entry in DEST_ROOT.iterdir():
        if entry.is_dir() and entry.name not in wanted:
            shutil.rmtree(entry)
            print(f"removed stale source: {entry.name}")


if __name__ == "__main__":
    main()
