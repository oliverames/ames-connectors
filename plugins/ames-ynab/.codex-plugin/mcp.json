{
  "mcpServers": {
    "ynab-mcp-server": {
      "command": "bash",
      "args": [
        "-c",
        "cd /tmp && npx -y @oliverames/ynab-mcp-server@latest"
      ],
      "env_vars": [
        "YNAB_API_TOKEN",
        "YNAB_BUDGET_ID",
        "YNAB_OP_PATH",
        "OP_SERVICE_ACCOUNT_TOKEN"
      ]
    }
  }
}
