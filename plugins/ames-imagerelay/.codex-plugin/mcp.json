{
  "mcpServers": {
    "imagerelay-mcp-server": {
      "command": "bash",
      "args": [
        "-c",
        "cd /tmp && npx -y imagerelay-mcp-server@latest"
      ],
      "env_vars": [
        "IMAGERELAY_API_KEY",
        "IMAGERELAY_SUBDOMAIN",
        "OP_SERVICE_ACCOUNT_TOKEN"
      ]
    }
  }
}
